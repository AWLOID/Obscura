local Library = {}
Library.__index = Library

local Players = game:GetService("Players")
local UserInputService = game:GetService("UserInputService")
local TweenService = game:GetService("TweenService")

local LocalPlayer = Players.LocalPlayer
local PlayerGui = LocalPlayer:WaitForChild("PlayerGui")

local THEME = {
    Accent = Color3.fromRGB(255, 30, 30),
    Background = Color3.fromRGB(16, 16, 16),
    Panel = Color3.fromRGB(22, 22, 22),
    Element = Color3.fromRGB(30, 30, 30),
    ElementHover = Color3.fromRGB(40, 40, 40),
    Stroke = Color3.fromRGB(45, 45, 45),
    Text = Color3.fromRGB(235, 235, 235),
    SubText = Color3.fromRGB(150, 150, 150),
    Track = Color3.fromRGB(55, 55, 55),
}

local function create(class, props)
    local inst = Instance.new(class)
    for k, v in pairs(props) do
        if k ~= "Parent" then
            inst[k] = v
        end
    end
    if props.Parent then
        inst.Parent = props.Parent
    end
    return inst
end

local function corner(inst, r)
    create("UICorner", { CornerRadius = UDim.new(0, r or 6), Parent = inst })
    return inst
end

local function stroke(inst, color, thickness)
    return create("UIStroke", {
        Color = color or THEME.Stroke,
        Thickness = thickness or 1,
        ApplyStrokeMode = Enum.ApplyStrokeMode.Border,
        Parent = inst,
    })
end

local function tween(inst, time, props)
    TweenService:Create(inst, TweenInfo.new(time, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), props):Play()
end

local function bindDrag(grabber, compute)
    local dragging = false
    local function update(input)
        compute(input.Position)
    end
    grabber.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            dragging = true
            update(input)
        end
    end)
    UserInputService.InputChanged:Connect(function(input)
        if dragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
            update(input)
        end
    end)
    UserInputService.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            dragging = false
        end
    end)
end

function Library:CreateWindow(config)
    config = config or {}
    local title = config.Title or "Lurk"
    local size = config.Size or UDim2.fromOffset(430, 320)
    local toggleKey = config.ToggleKey or Enum.KeyCode.RightControl

    local old = PlayerGui:FindFirstChild("LurkLibrary")
    if old then old:Destroy() end

    local screenGui = create("ScreenGui", {
        Name = "LurkLibrary",
        ResetOnSpawn = false,
        ZIndexBehavior = Enum.ZIndexBehavior.Sibling,
        IgnoreGuiInset = true,
        Parent = PlayerGui,
    })

    local activeClose = nil
    local function closeActivePopup()
        if activeClose then
            local fn = activeClose
            activeClose = nil
            fn()
        end
    end

    local function openPopup(listFrame, onClose)
        closeActivePopup()
        local catcher = create("TextButton", {
            BackgroundTransparency = 1,
            Text = "",
            AutoButtonColor = false,
            Size = UDim2.fromScale(1, 1),
            ZIndex = 900,
            Parent = screenGui,
        })
        listFrame.Parent = screenGui
        listFrame.ZIndex = 950
        for _, d in ipairs(listFrame:GetDescendants()) do
            if d:IsA("GuiObject") then
                d.ZIndex = d.ZIndex + 950
            end
        end
        activeClose = function()
            catcher:Destroy()
            onClose()
        end
        catcher.Activated:Connect(function()
            closeActivePopup()
        end)
    end

    local main = create("Frame", {
        Name = "Main",
        AnchorPoint = Vector2.new(0.5, 0.5),
        Position = UDim2.fromScale(0.5, 0.5),
        Size = size,
        BackgroundColor3 = THEME.Background,
        BorderSizePixel = 0,
        ClipsDescendants = true,
        Parent = screenGui,
    })
    corner(main, 10)
    stroke(main, THEME.Stroke, 1)

    local titleBar = create("Frame", {
        Size = UDim2.new(1, 0, 0, 38),
        BackgroundColor3 = THEME.Panel,
        BorderSizePixel = 0,
        Parent = main,
    })
    create("Frame", {
        Size = UDim2.new(1, 0, 0, 1),
        Position = UDim2.fromScale(0, 1),
        BackgroundColor3 = THEME.Stroke,
        BorderSizePixel = 0,
        Parent = titleBar,
    })
    create("TextLabel", {
        Size = UDim2.new(1, -20, 1, 0),
        Position = UDim2.fromOffset(16, 0),
        BackgroundTransparency = 1,
        Font = Enum.Font.GothamBold,
        Text = title,
        TextColor3 = THEME.Accent,
        TextSize = 16,
        TextXAlignment = Enum.TextXAlignment.Left,
        Parent = titleBar,
    })
    local closeBtn = create("TextButton", {
        AnchorPoint = Vector2.new(1, 0.5),
        Position = UDim2.new(1, -12, 0.5, 0),
        Size = UDim2.fromOffset(22, 22),
        BackgroundColor3 = THEME.Element,
        Text = "X",
        Font = Enum.Font.GothamBold,
        TextColor3 = THEME.Text,
        TextSize = 13,
        AutoButtonColor = false,
        Parent = titleBar,
    })
    corner(closeBtn, 6)

    do
        local dragging, startPos, startMouse
        titleBar.InputBegan:Connect(function(input)
            if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
                dragging = true
                startPos = main.Position
                startMouse = input.Position
                closeActivePopup()
            end
        end)
        UserInputService.InputChanged:Connect(function(input)
            if dragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
                local delta = input.Position - startMouse
                main.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
            end
        end)
        UserInputService.InputEnded:Connect(function(input)
            if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
                dragging = false
            end
        end)
    end

    local sidebar = create("Frame", {
        Position = UDim2.fromOffset(0, 38),
        Size = UDim2.new(0, 108, 1, -38),
        BackgroundColor3 = THEME.Panel,
        BorderSizePixel = 0,
        Parent = main,
    })
    create("Frame", {
        AnchorPoint = Vector2.new(1, 0),
        Position = UDim2.fromScale(1, 0),
        Size = UDim2.new(0, 1, 1, 0),
        BackgroundColor3 = THEME.Stroke,
        BorderSizePixel = 0,
        Parent = sidebar,
    })
    local logo = create("TextLabel", {
        Position = UDim2.fromOffset(0, 14),
        Size = UDim2.new(1, 0, 0, 54),
        BackgroundTransparency = 1,
        Font = Enum.Font.GothamBlack,
        Text = string.sub(title, 1, 1),
        TextColor3 = THEME.Text,
        TextSize = 34,
        Parent = sidebar,
    })
    local tabList = create("Frame", {
        Position = UDim2.fromOffset(0, 80),
        Size = UDim2.new(1, 0, 1, -90),
        BackgroundTransparency = 1,
        Parent = sidebar,
    })
    create("UIListLayout", {
        Padding = UDim.new(0, 4),
        SortOrder = Enum.SortOrder.LayoutOrder,
        Parent = tabList,
    })
    create("UIPadding", { PaddingLeft = UDim.new(0, 10), PaddingRight = UDim.new(0, 10), Parent = tabList })

    local contentArea = create("Frame", {
        Position = UDim2.fromOffset(108, 38),
        Size = UDim2.new(1, -108, 1, -38),
        BackgroundTransparency = 1,
        Parent = main,
    })
    local tabHeader = create("TextLabel", {
        Position = UDim2.fromOffset(18, 12),
        Size = UDim2.new(1, -36, 0, 24),
        BackgroundTransparency = 1,
        Font = Enum.Font.GothamBold,
        Text = "",
        TextColor3 = THEME.Text,
        TextSize = 18,
        TextXAlignment = Enum.TextXAlignment.Left,
        Parent = contentArea,
    })

    local window = setmetatable({}, Library)
    window._screenGui = screenGui
    window._main = main
    window._tabs = {}
    window._tabList = tabList
    window._contentArea = contentArea
    window._tabHeader = tabHeader
    window._title = title
    window._tabButtons = {}
    window._current = nil

    local function selectTab(name)
        for n, frame in pairs(window._tabs) do
            frame.Visible = (n == name)
        end
        for n, btn in pairs(window._tabButtons) do
            tween(btn.label, 0.15, { TextColor3 = (n == name) and THEME.Accent or THEME.SubText })
        end
        tabHeader.Text = name
        window._current = name
        closeActivePopup()
    end
    window._selectTab = selectTab

    closeBtn.Activated:Connect(function()
        closeActivePopup()
        tween(main, 0.18, { Size = UDim2.fromOffset(size.X.Offset, 0) })
        task.wait(0.18)
        main.Visible = false
        main.Size = size
    end)

    local toggleBtn = create("TextButton", {
        AnchorPoint = Vector2.new(1, 1),
        Position = UDim2.new(1, -22, 1, -22),
        Size = UDim2.fromOffset(54, 54),
        BackgroundColor3 = THEME.Panel,
        Text = string.sub(title, 1, 1),
        Font = Enum.Font.GothamBlack,
        TextColor3 = THEME.Accent,
        TextSize = 26,
        AutoButtonColor = false,
        Parent = screenGui,
    })
    corner(toggleBtn, 27)
    stroke(toggleBtn, THEME.Stroke, 1)
    local function toggleMenu()
        main.Visible = not main.Visible
        if not main.Visible then closeActivePopup() end
    end
    toggleBtn.Activated:Connect(toggleMenu)
    UserInputService.InputBegan:Connect(function(input, gp)
        if not gp and input.KeyCode == toggleKey then
            toggleMenu()
        end
    end)

    window._openPopup = openPopup
    window._closePopup = closeActivePopup

    return window
end

function Library:CreateTab(name)
    local tabButton = create("TextButton", {
        Size = UDim2.new(1, 0, 0, 30),
        BackgroundTransparency = 1,
        Text = "",
        AutoButtonColor = false,
        Parent = self._tabList,
    })
    local tabLabel = create("TextLabel", {
        Size = UDim2.fromScale(1, 1),
        BackgroundTransparency = 1,
        Font = Enum.Font.GothamMedium,
        Text = name,
        TextColor3 = THEME.SubText,
        TextSize = 15,
        TextXAlignment = Enum.TextXAlignment.Left,
        Parent = tabButton,
    })
    self._tabButtons[name] = { button = tabButton, label = tabLabel }

    local scroll = create("ScrollingFrame", {
        Position = UDim2.fromOffset(8, 44),
        Size = UDim2.new(1, -16, 1, -52),
        BackgroundTransparency = 1,
        BorderSizePixel = 0,
        ScrollBarThickness = 4,
        ScrollBarImageColor3 = THEME.SubText,
        CanvasSize = UDim2.new(0, 0, 0, 0),
        AutomaticCanvasSize = Enum.AutomaticSize.Y,
        ScrollingDirection = Enum.ScrollingDirection.Y,
        Visible = false,
        Parent = self._contentArea,
    })
    create("UIListLayout", {
        Padding = UDim.new(0, 8),
        SortOrder = Enum.SortOrder.LayoutOrder,
        Parent = scroll,
    })
    create("UIPadding", {
        PaddingTop = UDim.new(0, 2),
        PaddingBottom = UDim.new(0, 14),
        PaddingLeft = UDim.new(0, 2),
        PaddingRight = UDim.new(0, 12),
        Parent = scroll,
    })

    self._tabs[name] = scroll
    tabButton.Activated:Connect(function()
        self._selectTab(name)
    end)
    if not self._current then
        self._selectTab(name)
    end

    local tab = setmetatable({}, { __index = Library })
    tab._window = self
    tab._scroll = scroll
    return tab
end

local function baseRow(scroll, height)
    local row = create("Frame", {
        Size = UDim2.new(1, 0, 0, height or 38),
        BackgroundColor3 = THEME.Element,
        BorderSizePixel = 0,
        Parent = scroll,
    })
    corner(row, 6)
    create("UIPadding", { PaddingLeft = UDim.new(0, 12), PaddingRight = UDim.new(0, 12), Parent = row })
    return row
end

local function rowLabel(row, text)
    return create("TextLabel", {
        Size = UDim2.new(1, -50, 1, 0),
        BackgroundTransparency = 1,
        Font = Enum.Font.GothamMedium,
        Text = text,
        TextColor3 = THEME.Text,
        TextSize = 14,
        TextXAlignment = Enum.TextXAlignment.Left,
        Parent = row,
    })
end

