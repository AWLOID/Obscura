function Library:AddColorPicker(config)
    local row = baseRow(self._scroll)
    rowLabel(row, config.Text or "Color")
    local color = config.Default or THEME.Accent
    local swatch = create("Frame", {
        AnchorPoint = Vector2.new(1, 0.5),
        Position = UDim2.new(1, 0, 0.5, 0),
        Size = UDim2.fromOffset(38, 22),
        BackgroundColor3 = color,
        BorderSizePixel = 0,
        Parent = row,
    })
    corner(swatch, 5)
    stroke(swatch, THEME.Stroke, 1)
    local btn = create("TextButton", { Size = UDim2.fromScale(1, 1), BackgroundTransparency = 1, Text = "", Parent = row })

    local h, s, v = color:ToHSV()

    local function buildPicker()
        local panel = create("Frame", {
            BackgroundColor3 = THEME.Panel,
            BorderSizePixel = 0,
            Size = UDim2.fromOffset(200, 200),
            Position = UDim2.fromOffset(math.clamp(row.AbsolutePosition.X + row.AbsoluteSize.X - 200, 8, 9999), row.AbsolutePosition.Y + row.AbsoluteSize.Y + 4),
        })
        corner(panel, 8)
        stroke(panel, THEME.Stroke, 1)
        create("UIPadding", { PaddingTop = UDim.new(0, 10), PaddingBottom = UDim.new(0, 10), PaddingLeft = UDim.new(0, 10), PaddingRight = UDim.new(0, 10), Parent = panel })

        local sv = create("Frame", {
            Size = UDim2.new(1, 0, 0, 130),
            BackgroundColor3 = Color3.fromHSV(h, 1, 1),
            BorderSizePixel = 0,
            Parent = panel,
        })
        corner(sv, 6)
        local white = create("Frame", { Size = UDim2.fromScale(1, 1), BackgroundColor3 = Color3.new(1, 1, 1), BorderSizePixel = 0, Parent = sv })
        corner(white, 6)
        create("UIGradient", { Color = ColorSequence.new(Color3.new(1, 1, 1)), Transparency = NumberSequence.new({ NumberSequenceKeypoint.new(0, 1), NumberSequenceKeypoint.new(1, 0) }), Rotation = 180, Parent = white })
        local black = create("Frame", { Size = UDim2.fromScale(1, 1), BackgroundColor3 = Color3.new(0, 0, 0), BorderSizePixel = 0, Parent = sv })
        corner(black, 6)
        create("UIGradient", { Color = ColorSequence.new(Color3.new(0, 0, 0)), Transparency = NumberSequence.new({ NumberSequenceKeypoint.new(0, 1), NumberSequenceKeypoint.new(1, 0) }), Rotation = 90, Parent = black })
        local svCursor = create("Frame", {
            AnchorPoint = Vector2.new(0.5, 0.5),
            Size = UDim2.fromOffset(10, 10),
            BackgroundColor3 = Color3.new(1, 1, 1),
            BorderSizePixel = 0,
            ZIndex = 5,
            Position = UDim2.fromScale(s, 1 - v),
            Parent = sv,
        })
        corner(svCursor, 5)
        stroke(svCursor, Color3.new(0, 0, 0), 1)

        local hue = create("Frame", {
            Position = UDim2.new(0, 0, 0, 140),
            Size = UDim2.new(1, 0, 0, 16),
            BorderSizePixel = 0,
            Parent = panel,
        })
        corner(hue, 5)
        create("UIGradient", { Color = ColorSequence.new({
            ColorSequenceKeypoint.new(0, Color3.fromRGB(255, 0, 0)),
            ColorSequenceKeypoint.new(0.17, Color3.fromRGB(255, 255, 0)),
            ColorSequenceKeypoint.new(0.33, Color3.fromRGB(0, 255, 0)),
            ColorSequenceKeypoint.new(0.5, Color3.fromRGB(0, 255, 255)),
            ColorSequenceKeypoint.new(0.67, Color3.fromRGB(0, 0, 255)),
            ColorSequenceKeypoint.new(0.83, Color3.fromRGB(255, 0, 255)),
            ColorSequenceKeypoint.new(1, Color3.fromRGB(255, 0, 0)),
        }), Parent = hue })
        local hueCursor = create("Frame", {
            AnchorPoint = Vector2.new(0.5, 0.5),
            Size = UDim2.new(0, 4, 1, 4),
            BackgroundColor3 = Color3.new(1, 1, 1),
            BorderSizePixel = 0,
            ZIndex = 5,
            Position = UDim2.fromScale(h, 0.5),
            Parent = hue,
        })
        corner(hueCursor, 2)
        stroke(hueCursor, Color3.new(0, 0, 0), 1)

        local function apply()
            color = Color3.fromHSV(h, s, v)
            swatch.BackgroundColor3 = color
            sv.BackgroundColor3 = Color3.fromHSV(h, 1, 1)
            svCursor.Position = UDim2.fromScale(s, 1 - v)
            hueCursor.Position = UDim2.fromScale(h, 0.5)
            if config.Callback then config.Callback(color) end
        end
        bindDrag(sv, function(pos)
            s = math.clamp((pos.X - sv.AbsolutePosition.X) / sv.AbsoluteSize.X, 0, 1)
            v = 1 - math.clamp((pos.Y - sv.AbsolutePosition.Y) / sv.AbsoluteSize.Y, 0, 1)
            apply()
        end)
        bindDrag(hue, function(pos)
            h = math.clamp((pos.X - hue.AbsolutePosition.X) / hue.AbsoluteSize.X, 0, 1)
            apply()
        end)
        return panel
    end

    btn.Activated:Connect(function()
        local panel = buildPicker()
        self._window._openPopup(panel, function()
            panel:Destroy()
        end)
    end)
    return { Get = function() return color end }
end

return Library
