--[[
    ============================================================
    Lurk UI Library — мобильное GUI-меню для Roblox (тёмная тема)
    ============================================================

    ПОДКЛЮЧЕНИЕ (пример):
        local Lurk = loadstring(game:HttpGet("https://example.com/Lurk.lua"))()
        local Window = Lurk:CreateWindow({ Name = "Lurk" })
        local Tab1 = Window:AddTab("Tab1")
        Tab1:AddToggle({ Name = "Example", Default = false, Callback = function(v) end })

    ПУБЛИЧНЫЙ API:
        Lurk:CreateWindow(config) -> Window
            config = {
                Name = "Lurk",
                AccentColor = Color3.fromRGB(255, 30, 30),
                Size = UDim2.fromOffset(430, 320),
                SidebarWidth = 108,
                OpenButtonText = "L",
            }

        Window:AddTab(name) -> Tab
        Window:SelectTab(name)
        Window:SetAccentColor(color3)
        Window:Toggle(open)
        Window:Notify(config)   -- config = { Title = "...", Text = "...", Duration = 4 }
        Window:Destroy()

        Tab:AddLabel(text) -> Instance
        Tab:AddToggle(config) -> API { Set(value), Get() }
        Tab:AddSlider(config) -> API { Set(value), Get() }
        Tab:AddButton(config) -> API
        Tab:AddDropdown(config) -> API { Set(value), Get() }
        Tab:AddColorPicker(config) -> API { Set(color3), Get() }
        Tab:AddTextbox(config) -> API { Set(text), Get() }
        Tab:AddKeybind(config) -> API { Set(keycode), Get() }
        Tab:AddSection(text) -> Instance
        Tab:AddDivider() -> Instance
        Tab:AddParagraph(config) -> API { Set(text), Get() }
        Tab:AddMultiDropdown(config) -> API { Set(list), Get() }

    СТРУКТУРА ФАЙЛА:
        1. СЕРВИСЫ И УТИЛИТЫ
        2. ВНУТРЕННИЙ РЕЕСТР ОВЕРЛЕЕВ (дропдауны, цветовые пикеры, поверх скролла)
        3. КОНСТРУКТОР ЭЛЕМЕНТОВ (Toggle, Slider, Button, Dropdown, MultiDropdown, ColorPicker, Textbox, Keybind, Label, Section, Divider, Paragraph)
        4. КОНСТРУКТОР ВКЛАДКИ (Tab)
        5. КОНСТРУКТОР ОКНА (Window / CreateWindow)
        6. ПУБЛИЧНЫЙ МОДУЛЬ (Lurk)
]]

