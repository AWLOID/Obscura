function Library:AddToggle(config)
    local row = baseRow(self._scroll)
    rowLabel(row, config.Text or "Toggle")
    local state = config.Default or false
    local box = create("Frame", {
        AnchorPoint = Vector2.new(1, 0.5),
        Position = UDim2.new(1, 0, 0.5, 0),
        Size = UDim2.fromOffset(40, 22),
        BackgroundColor3 = state and THEME.Accent or THEME.Track,
        BorderSizePixel = 0,
        Parent = row,
    })
    corner(box, 11)
    local dot = create("Frame", {
        AnchorPoint = Vector2.new(0, 0.5),
        Position = state and UDim2.new(1, -20, 0.5, 0) or UDim2.new(0, 2, 0.5, 0),
        Size = UDim2.fromOffset(18, 18),
        BackgroundColor3 = Color3.fromRGB(245, 245, 245),
        BorderSizePixel = 0,
        Parent = box,
    })
    corner(dot, 9)
    local btn = create("TextButton", { Size = UDim2.fromScale(1, 1), BackgroundTransparency = 1, Text = "", Parent = row })
    local function set(v)
        state = v
        tween(box, 0.15, { BackgroundColor3 = state and THEME.Accent or THEME.Track })
        tween(dot, 0.15, { Position = state and UDim2.new(1, -20, 0.5, 0) or UDim2.new(0, 2, 0.5, 0) })
        if config.Callback then config.Callback(state) end
    end
    btn.Activated:Connect(function()
        self._window._closePopup()
        set(not state)
    end)
    return { Set = set, Get = function() return state end }
end

function Library:AddSlider(config)
    local min = config.Min or 0
    local max = config.Max or 100
    local decimals = config.Decimals or 0
    local value = config.Default or min
    local row = baseRow(self._scroll, 50)
    local label = create("TextLabel", {
        Position = UDim2.fromOffset(0, 6),
        Size = UDim2.new(1, 0, 0, 16),
        BackgroundTransparency = 1,
        Font = Enum.Font.GothamMedium,
        Text = (config.Text or "Slider") .. ": " .. tostring(value),
        TextColor3 = THEME.Text,
        TextSize = 14,
        TextXAlignment = Enum.TextXAlignment.Left,
        Parent = row,
    })
    local track = create("Frame", {
        AnchorPoint = Vector2.new(0, 0.5),
        Position = UDim2.new(0, 0, 1, -14),
        Size = UDim2.new(1, 0, 0, 6),
        BackgroundColor3 = THEME.Track,
        BorderSizePixel = 0,
        Parent = row,
    })
    corner(track, 3)
    local fill = create("Frame", {
        Size = UDim2.fromScale((value - min) / (max - min), 1),
        BackgroundColor3 = THEME.Accent,
        BorderSizePixel = 0,
        Parent = track,
    })
    corner(fill, 3)
    local knob = create("Frame", {
        AnchorPoint = Vector2.new(0.5, 0.5),
        Position = UDim2.new((value - min) / (max - min), 0, 0.5, 0),
        Size = UDim2.fromOffset(14, 14),
        BackgroundColor3 = Color3.fromRGB(245, 245, 245),
        BorderSizePixel = 0,
        ZIndex = 3,
        Parent = track,
    })
    corner(knob, 7)
    local function setFromRatio(r)
        r = math.clamp(r, 0, 1)
        local raw = min + (max - min) * r
        local mult = 10 ^ decimals
        value = math.floor(raw * mult + 0.5) / mult
        local ratio = (value - min) / (max - min)
        fill.Size = UDim2.fromScale(ratio, 1)
        knob.Position = UDim2.new(ratio, 0, 0.5, 0)
        label.Text = (config.Text or "Slider") .. ": " .. tostring(value)
        if config.Callback then config.Callback(value) end
    end
    bindDrag(track, function(pos)
        self._window._closePopup()
        setFromRatio((pos.X - track.AbsolutePosition.X) / track.AbsoluteSize.X)
    end)
    return { Set = function(v) setFromRatio((v - min) / (max - min)) end, Get = function() return value end }
end

function Library:AddDropdown(config)
    local options = config.Options or {}
    local multi = config.Multi or false
    local selected = multi and {} or (config.Default or (options[1]))
    if multi and config.Default then
        for _, v in ipairs(config.Default) do selected[v] = true end
    end
    local row = baseRow(self._scroll)
    rowLabel(row, config.Text or "Dropdown")
    local function displayText()
        if multi then
            local t = {}
            for k, v in pairs(selected) do if v then t[#t + 1] = k end end
            return #t > 0 and table.concat(t, ", ") or "..."
        end
        return tostring(selected or "...")
    end
    local valueLabel = create("TextLabel", {
        AnchorPoint = Vector2.new(1, 0.5),
        Position = UDim2.new(1, -18, 0.5, 0),
        Size = UDim2.new(0, 130, 1, 0),
        BackgroundTransparency = 1,
        Font = Enum.Font.GothamMedium,
        Text = displayText(),
        TextColor3 = THEME.Accent,
        TextSize = 13,
        TextXAlignment = Enum.TextXAlignment.Right,
        TextTruncate = Enum.TextTruncate.AtEnd,
        Parent = row,
    })
    create("TextLabel", {
        AnchorPoint = Vector2.new(1, 0.5),
        Position = UDim2.new(1, 0, 0.5, 0),
        Size = UDim2.fromOffset(12, 12),
        BackgroundTransparency = 1,
        Font = Enum.Font.GothamBold,
        Text = "v",
        TextColor3 = THEME.SubText,
        TextSize = 12,
        Parent = row,
    })
    local btn = create("TextButton", { Size = UDim2.fromScale(1, 1), BackgroundTransparency = 1, Text = "", Parent = row })

    local function buildList()
        local list = create("Frame", {
            BackgroundColor3 = THEME.Panel,
            BorderSizePixel = 0,
            Size = UDim2.fromOffset(row.AbsoluteSize.X, math.min(#options, 5) * 30 + 8),
            Position = UDim2.fromOffset(row.AbsolutePosition.X, row.AbsolutePosition.Y + row.AbsoluteSize.Y + 4),
        })
        corner(list, 6)
        stroke(list, THEME.Stroke, 1)
        local inner = create("ScrollingFrame", {
            Size = UDim2.fromScale(1, 1),
            BackgroundTransparency = 1,
            BorderSizePixel = 0,
            ScrollBarThickness = 3,
            ScrollBarImageColor3 = THEME.SubText,
            CanvasSize = UDim2.new(0, 0, 0, 0),
            AutomaticCanvasSize = Enum.AutomaticSize.Y,
            Parent = list,
        })
        create("UIListLayout", { Padding = UDim.new(0, 2), Parent = inner })
        create("UIPadding", { PaddingTop = UDim.new(0, 4), PaddingBottom = UDim.new(0, 4), PaddingLeft = UDim.new(0, 4), PaddingRight = UDim.new(0, 4), Parent = inner })
        for _, opt in ipairs(options) do
            local isSel = multi and selected[opt] or (selected == opt)
            local optBtn = create("TextButton", {
                Size = UDim2.new(1, 0, 0, 26),
                BackgroundColor3 = THEME.Element,
                BackgroundTransparency = isSel and 0 or 1,
                Font = Enum.Font.GothamMedium,
                Text = "  " .. tostring(opt),
                TextColor3 = isSel and THEME.Accent or THEME.Text,
                TextSize = 13,
                TextXAlignment = Enum.TextXAlignment.Left,
                AutoButtonColor = false,
                Parent = inner,
            })
            corner(optBtn, 4)
            optBtn.Activated:Connect(function()
                if multi then
                    selected[opt] = not selected[opt]
                    optBtn.BackgroundTransparency = selected[opt] and 0 or 1
                    optBtn.TextColor3 = selected[opt] and THEME.Accent or THEME.Text
                    valueLabel.Text = displayText()
                    if config.Callback then config.Callback(selected) end
                else
                    selected = opt
                    valueLabel.Text = displayText()
                    self._window._closePopup()
                    if config.Callback then config.Callback(selected) end
                end
            end)
        end
        return list
    end

    btn.Activated:Connect(function()
        local list = buildList()
        self._window._openPopup(list, function()
            list:Destroy()
        end)
    end)
    return { Get = function() return selected end }
end

