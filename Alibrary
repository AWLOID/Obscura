            Name = "MultiOptionsHolder_" .. name,
            BackgroundColor3 = Color3.fromRGB(16, 16, 16),
            BorderSizePixel = 0,
            Size = UDim2.fromOffset(0, #options * 24),
            Visible = false,
            ZIndex = 200,
            Parent = ScreenGui,
        })

        NewInstance("UIStroke", {
            Name = "OptionsStroke",
            Color = Color3.fromRGB(60, 60, 60),
            Thickness = 1,
            Parent = optionsHolder,
        })

        NewInstance("UIListLayout", {
            Name = "OptionsLayout",
            SortOrder = Enum.SortOrder.LayoutOrder,
            Parent = optionsHolder,
        })

        local isOpen = false
        local optionChecks = {}

        local function SelectedList()
            local list = {}
            for _, opt in ipairs(options) do
                if selected[opt] then
                    table.insert(list, opt)
                end
            end
            return list
        end

        local function UpdateBoxText()
            local list = SelectedList()
            if #list == 0 then
                box.Text = "  ..."
            else
                box.Text = "  " .. table.concat(list, ", ")
            end
        end

        local function Close()
            isOpen = false
            optionsHolder.Visible = false
        end

        local function RebuildOptions()
            for _, child in ipairs(optionsHolder:GetChildren()) do
                if child:IsA("TextButton") then
                    child:Destroy()
                end
            end
            optionChecks = {}
            for _, opt in ipairs(options) do
                local optBtn = NewInstance("TextButton", {
                    Name = "Option_" .. tostring(opt),
                    BackgroundColor3 = Color3.fromRGB(16, 16, 16),
                    BorderSizePixel = 0,
                    AutoButtonColor = false,
                    Size = UDim2.new(1, 0, 0, 24),
                    Font = Enum.Font.Gotham,
                    TextSize = 13,
                    TextColor3 = Color3.fromRGB(200, 200, 200),
                    TextXAlignment = Enum.TextXAlignment.Left,
                    Text = "  " .. tostring(opt),
                    ZIndex = optionsHolder.ZIndex + 1,
                    Parent = optionsHolder,
                })

                local check = NewInstance("Frame", {
                    Name = "Check",
                    AnchorPoint = Vector2.new(1, 0.5),
                    Position = UDim2.new(1, -8, 0.5, 0),
                    Size = UDim2.fromOffset(10, 10),
                    BackgroundColor3 = Accent.Value,
                    BorderSizePixel = 0,
                    BackgroundTransparency = selected[opt] and 0 or 1,
                    ZIndex = optBtn.ZIndex + 1,
                    Parent = optBtn,
                })

                NewInstance("UIStroke", {
                    Color = Color3.fromRGB(80, 80, 80),
                    Thickness = 1,
                    Parent = check,
                })

                Accent.Changed:Connect(function(color)
                    check.BackgroundColor3 = color
                end)

                optionChecks[opt] = check

                optBtn.MouseButton1Click:Connect(function()
                    selected[opt] = not selected[opt]
                    check.BackgroundTransparency = selected[opt] and 0 or 1
                    UpdateBoxText()
                    if callback then
                        callback(SelectedList())
                    end
                end)
            end
            optionsHolder.Size = UDim2.fromOffset(optionsHolder.AbsoluteSize.X, #options * 24)
        end

        RebuildOptions()
        UpdateBoxText()

        local function Open()
            CloseAllOverlaysExcept(optionsHolder)
            local boxPos = box.AbsolutePosition
            local boxSize = box.AbsoluteSize
            optionsHolder.Position = UDim2.fromOffset(boxPos.X, boxPos.Y + boxSize.Y + 2)
            optionsHolder.Size = UDim2.fromOffset(boxSize.X, #options * 24)
            optionsHolder.Visible = true
            isOpen = true
        end

        box.MouseButton1Click:Connect(function()
            if isOpen then
                Close()
            else
                Open()
            end
        end)

        RegisterOverlay(optionsHolder, box, function() return isOpen end, Close)

        local api = {}
        function api.Set(values)
            selected = {}
            for _, item in ipairs(values or {}) do
                selected[item] = true
            end
            for opt, check in pairs(optionChecks) do
                check.BackgroundTransparency = selected[opt] and 0 or 1
            end
            UpdateBoxText()
        end
        function api.Get()
            return SelectedList()
        end
        function api.SetOptions(newOptions)
            options = newOptions
            RebuildOptions()
            UpdateBoxText()
        end
        return api
    end

    return Factory
end

